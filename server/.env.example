ANTHROPIC_API_KEY=
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json

# ── Model ─────────────────────────────────────────────────────────────────────
# Options: claude-haiku-4-5 | claude-sonnet-4-6 | claude-opus-4-6
MODEL=claude-haiku-4-5

# ── Server ────────────────────────────────────────────────────────────────────
# PORT=3000

# ── Tools (set to 'true' to enable) ──────────────────────────────────────────
TOOL_WEB_SEARCH=false
TAVILY_API_KEY=
# Model to use when tools are active (needs to be better at instruction following)
MODEL_WITH_TOOLS=claude-sonnet-4-6
